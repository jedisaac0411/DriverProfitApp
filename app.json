{
  "expo": {
    "name": "GigProfit",
    "slug": "gigprofit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gigprofit",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.DriverProfitApp"
    },

    "android": {
      "package": "com.anonymous.DriverProfitApp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0B0F1A"
      }
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#0B0F1A"
        }
      ]
    ],

    "extra": {
      "eas": {
        "projectId": "f8a1a4ad-b859-4aae-aa8f-c2f0a8b0bfaa"
      }
    }
  }
}